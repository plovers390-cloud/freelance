# ============================================
# FrellancerWebApp — Backend Environment Config
# ============================================
# Copy to .env and fill in your values.
# On Render, set these in Dashboard → Environment.
# ============================================

# Server
PORT=5000
NODE_ENV=production

# ─── Database ────────────────────────────────
# Option 1: Render / hosted PostgreSQL (single URL)
DB_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# Option 2: Local development (individual vars)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_db_password
# DB_NAME=frellancer_db

# ─── JWT ─────────────────────────────────────
JWT_ACCESS_SECRET=your_32+_char_random_secret_here
JWT_REFRESH_SECRET=your_different_32+_char_random_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS / Frontend ────────────────────────
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGIN=https://your-custom-domain.com

# ─── Razorpay ───────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Email (Nodemailer) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
